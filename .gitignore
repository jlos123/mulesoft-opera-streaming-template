# Root .gitignore.
# Only NEVER-TRACK things live here (real secrets, build output, OS/IDE cruft).

# --- Build output ---
**/target/
**/.mule/
*.class
*.jar
*.war
*.ear
velocity.log

# --- Real secrets (only the *.sample pair is ever tracked) ---
**/src/main/resources/secure.properties

# --- Node (the OHIP simulator) ---
**/node_modules/

# --- OS / IDE cruft ---
.DS_Store
Thumbs.db
*.swp
*.bak
*~.nib
.tooling-project/

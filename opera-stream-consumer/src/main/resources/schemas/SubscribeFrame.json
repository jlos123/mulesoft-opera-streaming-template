{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "type", "payload"],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["query"],
      "properties": {
        "query": { "type": "string" }
      }
    }
  }
}
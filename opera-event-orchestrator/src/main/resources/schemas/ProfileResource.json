{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "getProfile response subtree (crm.json #/definitions/profile) — only the paths the orchestrator transform reads.",
  "type": "object",
  "properties": {
    "profileIdList": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "idExtension": { "type": "string" }
        }
      }
    },
    "profileDetails": {
      "type": "object",
      "properties": {
        "profileType": { "type": "string" },
        "statusCode": { "type": "string" },
        "createDateTime": { "type": "string" },
        "lastModifyDateTime": { "type": "string" },
        "customer": {
          "type": "object",
          "properties": {
            "gender": { "type": "string" },
            "birthDate": { "type": "string" },
            "language": { "type": "string" },
            "nationality": { "type": "string" },
            "vipStatus": { "type": "string" },
            "personName": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "namePrefix": { "type": "string" },
                  "givenName": { "type": "string" },
                  "middleName": { "type": "string" },
                  "surname": { "type": "string" }
                }
              }
            }
          }
        },
        "emails": {
          "type": "object",
          "properties": {
            "emailInfo": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "object",
                    "properties": {
                      "emailAddress": { "type": "string" },
                      "primaryInd": { "type": "boolean" }
                    }
                  }
                }
              }
            }
          }
        },
        "telephones": {
          "type": "object",
          "properties": {
            "telephoneInfo": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "telephone": {
                    "type": "object",
                    "properties": {
                      "phoneNumber": { "type": "string" },
                      "primaryInd": { "type": "boolean" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
<?xml version="1.0" encoding="UTF-8"?>
<!--
  App-level logging. Console-only: routes this app's loggers to stdout so they appear in the IDE/terminal
  locally and are captured by CloudHub's log stream in the cloud (stdout is the source of truth there).
  No file appender - on CloudHub a RollingFile just duplicates the console stream to disk nobody reads.
-->
<Configuration>
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} %-5p [%c{1}] %m%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <!-- This app's flows and DataWeave loggers. -->
        <AsyncLogger name="com.datafoundations.opera" level="INFO"/>
        <!-- Quieten noisy connector/runtime chatter; raise to DEBUG when troubleshooting. -->
        <AsyncLogger name="org.mule.service.http" level="WARN"/>
        <AsyncLogger name="com.mulesoft.mule.runtime" level="WARN"/>
        <Root level="INFO">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
